# --- Specifico di harmony-book ---
# Handoff/ricerca personale dello stack: non committare ne pushare.
# Va letta nella sessione ripresa per decidere lo stack e riempire le schede claude.
transform-into-claude-md/

# --- Contenuto privato e output di build di harmony-book ---
# Il contenuto vendibile del libro non va mai versionato in questa repo pubblica.
/manuscript/
# Output di compilazione (lilypond-book + latexmk).
/build/

# --- Sistema di progetto portabile: livello privato e ignorato (sezione 6/10) ---
# Da unire al .gitignore del progetto. Inserire PRIMA di creare _notes/, altrimenti
# la cartella finisce indicizzata.

# Livello privato e verboso (ancorato alla radice: NON tocca .claude/templates/_notes/)
/_notes/

# Override personali e permessi personali (ancorato: NON tocca .claude/templates/CLAUDE.local.md)
/CLAUDE.local.md
.claude/settings.local.json

# Estratti temporanei dei .docx (cartelle scratch)
/_notes/.tmp-docx-*/
.tmp-docx-*/

# Documenti Word grezzi (binari). Dichiarare qui le eventuali eccezioni curate, es:
#   *.docx
#   !docs/specifica-ufficiale.docx
*.docx

# Ambiente materializzato (sezione 13): si versiona il manifesto, si ignora il derivato.
# Python
.venv/
__pycache__/
*.pyc
# Node
node_modules/
# LaTeX: il .tex/.lytex/.ly e' la fonte, il PDF e gli ausiliari sono derivati. Attivo.
*.aux
*.log
*.out
*.toc
*.lof
*.lot
*.fls
*.fdb_latexmk
*.synctex.gz
*.bbl
*.blg
*.bcf
*.run.xml
*.nav
*.snm
*.vrb
*.glo
*.gls
*.glg
*.ist
*.acn
*.acr
*.alg
*.idx
*.ind
*.ilg
*.pdf
# Ausiliari e immagini generati da lilypond-book fuori da build/ (best-effort).
*-systems.*
*.eps
